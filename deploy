#!/bin/bash

set -o errexit -o nounset -o pipefail

source venv/bin/activate

touch lock
exec {fd}< lock
if ! flock -n $fd; then
    echo already deploying >&2
    exit 1
fi

gixy nginx/nginx.conf

remote=root@mail.grapheneos.org

./sort-blocklist
./generate-blocklist
cp blocklist/client_access.cidr postfix/client_access.cidr

rsync -rpcv --delete --chmod=D755,F644 --fsync --preallocate dovecot $remote:/etc/
ssh $remote "mkdir -p /var/lib/rspamd/postfix && chmod 750 /var/lib/rspamd/postfix && chown rspamd:postfix /var/lib/rspamd/postfix"
rsync --delete -rpcv --chown root:root --chmod=F644 --fsync --preallocate rspamd/local.d/ $remote:/etc/rspamd/local.d/
rsync -rpcv --delete --chown root:rspamd --chmod=D750,F640 --fsync --preallocate dkim $remote:/etc/
rsync -rpcv --chmod=D755,F644 --fsync --preallocate postfix/{body_checks,client_access.cidr,header_checks,local_recipient,main.cf,master.cf,sender_access,sender_login,submission_header_checks,virtual,virtual_recipient} $remote:/etc/postfix
ssh $remote "postmap /etc/postfix/{local_recipient,sender_access,sender_login,virtual,virtual_recipient}"
rsync -rpcv --chmod=D755,F644 --fsync --preallocate systemd/system/{dovecot.service.d,postfix.service.d,remote-backup.service,remote-backup.timer,rspamd.service.d} $remote:/etc/systemd/system/
ssh $remote systemctl daemon-reload
rsync -pcv --chmod=755 --fsync --preallocate remote-backup $remote:/usr/local/bin/
rsync -pcv --chmod=644 --fsync --preallocate backup-public-key.txt cloud-archive.sh $remote:
rsync -rpcv --chmod=D755,F644 --fsync --preallocate nginx/{nginx.conf,mime.types} $remote:/etc/nginx/
ssh $remote systemctl reload nginx
