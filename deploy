#!/bin/bash

set -o errexit -o nounset -o pipefail

rsync() {
    command rsync -pcv --chmod=D755,F644 --preallocate "$@"
}

source venv/bin/activate

touch lock
exec {fd}< lock
if ! flock -n $fd; then
    echo already deploying >&2
    exit 1
fi

gixy nginx/nginx.conf

remote=root@mail.grapheneos.org

cp blocklist/{blocklist_{addr,esld,ip,text},tor_exit}.map rspamd/local.d/maps.d/

rsync -r --delete dovecot/ $remote:/etc/dovecot/
ssh $remote sievec /etc/dovecot/sieve/default.sieve

rsync valkey/valkey.conf $remote:/etc/valkey/valkey.conf
ssh $remote 'usermod -aG valkey rspamd &&
mkdir -p /var/lib/rspamd/postfix &&
chmod 750 /var/lib/rspamd/postfix &&
chown rspamd:postfix /var/lib/rspamd/postfix'
rsync -r --delete rspamd/local.d/ $remote:/etc/rspamd/local.d/
rsync -r --delete --chown root:rspamd --chmod=D750,F640 dkim $remote:/etc/

rsync postfix/{local_recipient,main.cf,master.cf,sender_login,submission_header_checks,virtual,virtual_recipient} $remote:/etc/postfix
ssh $remote "postmap /etc/postfix/{local_recipient,sender_login,virtual,virtual_recipient}"

rsync -r --delete systemd/system/{dovecot.service.d,postfix.service.d,remote-backup.service,remote-backup.timer,rspamd.service.d} $remote:/etc/systemd/system/
ssh $remote systemctl daemon-reload

rsync --chmod=755 remote-backup $remote:/usr/local/bin/
rsync backup-public-key.txt cloud-archive.sh $remote:

rsync nginx/{nginx.conf,mime.types} $remote:/etc/nginx/
ssh $remote systemctl reload nginx
