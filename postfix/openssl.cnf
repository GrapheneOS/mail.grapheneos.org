postfix = postfix_settings

[postfix_settings]
ssl_conf = postfix_ssl_conf

[postfix_ssl_conf]
system_default = postfix_system_default

[postfix_system_default]
SignatureAlgorithms = ECDSA+SHA256:ECDSA+SHA384:ECDSA+SHA512:RSA-PSS+SHA256:RSA-PSS+SHA384:RSA-PSS+SHA512:RSA+SHA256:RSA+SHA384:RSA+SHA512
